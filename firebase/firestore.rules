rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function userDocPath() {
      return /databases/$(database)/documents/users/$(request.auth.uid);
    }

    function isAdmin() {
      return signedIn() &&
        exists(userDocPath()) &&
        get(userDocPath()).data.role == 'admin';
    }

    function isShop() {
      return signedIn() &&
        exists(userDocPath()) &&
        get(userDocPath()).data.role == 'shop';
    }

    match /users/{uid} {
      allow read: if signedIn() && (request.auth.uid == uid || isAdmin());
      allow write: if isAdmin();
    }

    match /settings/{docId} {
      allow read: if signedIn();
      allow write: if isAdmin() && docId == 'global';
    }

    match /settings_logs/{id} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update, delete: if false;
    }

    match /orders/{orderId} {
      allow read: if signedIn() && (
        resource.data.shop_id == request.auth.uid ||
        isAdmin()
      );
      allow create: if isShop()
        && request.resource.data.shop_id == request.auth.uid;
      allow update, delete: if isAdmin();
    }
  }
}
